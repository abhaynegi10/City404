# City 404 — Environment Variables Template
# Copy this to .env.local and fill in your Firebase values

# Firebase Client SDK (public, safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Firebase Admin SDK (server-only, NEVER expose)
# Paste the entire service account JSON as a single line string
FIREBASE_SERVICE_ACCOUNT_KEY=

# App URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000
